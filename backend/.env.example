# Copy this file to `.env` (same folder) and fill in real values.
# `.env` is gitignored -- never commit real API keys.

# Required for the /chat endpoint (section 5)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: override the Claude model used by the chat agent.
# Defaults to "claude-sonnet-5" if unset.
ANTHROPIC_MODEL=claude-sonnet-5

# Optional: comma-separated list of extra allowed CORS origins for production
# frontend deployments (localhost:5173 is always allowed for local dev).
FRONTEND_ORIGINS=

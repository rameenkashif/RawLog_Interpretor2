# Python
backend/.venv/
__pycache__/
*.pyc
.pytest_cache/

# Environment secrets
backend/.env
.env

# Processed data cache (regenerate from raw LAS files; keep raw/ though)
backend/data/processed/*.parquet
backend/data/processed/*.meta.json
backend/data/models/*.joblib
backend/data/seismic_processed/*.npz
backend/data/seismic_processed/*.parquet
backend/data/seismic_processed/*.meta.json

# Manual well-tie stretch/squeeze control points (user-adjustable state, one
# file per well -- regenerable via the UI, not source data)
backend/data/synthetic_processed/*.json

# Dashboard-upload background pipeline cache (regenerable from re-upload)
backend/data/well_processing_cache/*.json

# Node / frontend
frontend/node_modules/
frontend/dist/
frontend/.vite/

